<UserControl x:Class="UI_application_UX.UserControl1 "
            xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
            xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
            xmlns:local="clr-namespace:UI_application_UX" xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
            mc:Ignorable="d"
            Background="{StaticResource Base_Color}">

  
        <materialDesign:ColorZone Height="Auto" Padding="16" Mode="Standard" Background="{StaticResource Accsent_Color}" Foreground="{StaticResource Base_Color}" MouseLeftButtonDown="header">

        <Grid>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">


                <Button  Click="Minisize" Foreground="{StaticResource Main_Color}" Style="{StaticResource MaterialDesignToolButton}">
                    <materialDesign:PackIcon Height="20" Width="20" Kind="WindowMinimize" />
                </Button>
                <!--最小化ボタン-->
                
                <Button  Click="Maxsize" Foreground="{StaticResource Main_Color}" Style="{StaticResource MaterialDesignToolButton}">
                    <materialDesign:PackIcon Height="20" Width="20" Kind="WindowMaximize" />
                </Button>
                <!--最大化ボタン-->

                
                <Button   Click="Exit_Button" Foreground="{StaticResource Main_Color}" Style="{StaticResource MaterialDesignToolButton}" Cursor="Hand">
                    <materialDesign:PackIcon Height="20" Width="20" Kind="WindowClose" Cursor="" />
                </Button>

            </StackPanel>


          
                <!--ハンバーガーメニュー-->
            <ToggleButton Width="50" Height="50"
                    HorizontalAlignment="Left"
     x:Name="MenuToggleButton"
     Click="MenuToggleButton_Click"
     Style="{StaticResource MaterialDesignHamburgerToggleButton}" />


                <!--<StackPanel Orientation="Horizontal" Cursor="">-->


            <Grid VerticalAlignment="Center" HorizontalAlignment="Center" >
                    <TextBlock Text="日本の文化" 
           FontFamily="HG行書体" 
           FontSize="24" 
           Foreground="{StaticResource Main_Color}" />
                </Grid>
            <!--アプリ　ロゴ-->

          




            <!--</StackPanel>-->

        </Grid>

    </materialDesign:ColorZone>

</UserControl>
